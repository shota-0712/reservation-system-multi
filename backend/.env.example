# Local development only.
# Do not paste production secrets into this file. Production Cloud Run must
# receive app secrets from Google Secret Manager via --set-secrets.

# Google Cloud Service Account
# Local only: path to a service account JSON file when Application Default
# Credentials are not available. Production Cloud Run uses its runtime service
# account and should not set GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# PostgreSQL
# Local example:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/reservation_dev
# Production:
# - Use Neon Postgres per salon.
# - Store DATABASE_URL in Secret Manager and expose it to Cloud Run with
#   --set-secrets, not as a plain text env var or GitHub Secret.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reservation_dev

# Google Sheets
# Non-secret identifier. DB is the reservation source of truth; keep this only
# for migration, template, or auxiliary settings use cases.
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Google Drive (メニュー画像保存先フォルダ)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# LINE Messaging API
# Local placeholder only. Store the production token in Secret Manager.
LINE_ACCESS_TOKEN=your_line_channel_access_token_here
ADMIN_LINE_ID=your_admin_line_user_id_here

# LIFF
# Non-secret LIFF application settings.
LIFF_ID=your_liff_id_here
# LINE Login channel ID for LIFF ID token verification (not a secret)
LINE_CHANNEL_ID=your_line_login_channel_id_here

# Server
PORT=8080
NODE_ENV=development

# Batch Scheduler
# Local placeholder only. Store the production scheduler secret in Secret Manager.
SCHEDULER_SECRET=your_secret_token_here

# Theme Colors (optional)
THEME_COLOR=#9b1c2c
THEME_COLOR_LIGHT=#b92b3d
THEME_COLOR_DARK=#7a1522
